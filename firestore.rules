rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS ABIERTAS PARA ZB PROPIEDADES
    // Permitimos lectura pública total en toda la base de datos para depuración
    // Las escrituras requieren ser el administrador configurado
    
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null && request.auth.token.email == 'skrsoftwarecr@gmail.com';
    }

    // Regla específica para leads (contactos) que permite creación pública
    match /leads/{leadId} {
      allow create: if true;
    }
  }
}