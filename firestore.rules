
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD ZB PROPIEDADES
    // Última actualización: 2024-05-21 11:30:00 (Forzando despliegue)

    // Permitir que cualquier usuario (incluso sin loguearse) vea las propiedades y lotes
    match /properties/{propertyId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    match /lots/{lotId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }

    // Regla global de lectura para asegurar que el catálogo siempre sea visible
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
  }
}
