
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas simplificadas para ZB Propiedades
    // Permitir lectura pública de propiedades y lotes
    match /properties/{propertyId} {
      allow read, list: if true;
    }
    match /lots/{lotId} {
      allow read, list: if true;
    }
    // Permitir acceso administrativo básico (puedes restringir esto más tarde)
    match /{document=**} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
  }
}
