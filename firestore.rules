
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PERMISOS GLOBALES PARA ZB PROPIEDADES
    // Permitir que cualquier visitante vea las propiedades y lotes
    match /{document=**} {
      allow read, list: if true;
      // Solo el administrador (tú) podrá escribir/editar después de loguearse
      allow write: if request.auth != null;
    }
  }
}
