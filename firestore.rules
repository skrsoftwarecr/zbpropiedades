
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS GLOBALES PARA ZB PROPIEDADES (Actualizadas: 2024-05-20)
    // Permitir lectura pública para que el catálogo sea visible para todos
    match /properties/{propertyId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }
    
    match /lots/{lotId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }

    // Regla de respaldo para cualquier otra colección
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
