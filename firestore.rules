
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas actualizadas para ZB Propiedades
    // Este comentario fuerza la redistribución de las reglas.

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'skrsoftwarecr@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /admins/{adminId} {
      allow get: if request.auth != null;
      allow list, write: if isAdmin();
    }

    // Permitir lectura pública de propiedades y lotes
    match /properties/{propertyId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /lots/{lotId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Los leads (contactos) pueden ser creados por cualquiera
    match /leads/{leadId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
