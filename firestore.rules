rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE ACCESO ZB PROPIEDADES
    // Actualizado: 2024-05-20 15:30 (Force redeploy)
    
    match /{document=**} {
      // Permitimos lectura y listado público para que el catálogo sea visible
      allow read, list: if true;
      
      // Escritura restringida al administrador del sitio
      allow write: if request.auth != null && request.auth.token.email == 'skrsoftwarecr@gmail.com';
    }

    // Regla para leads (contactos) que permite creación pública desde formularios de contacto
    match /leads/{leadId} {
      allow create: if true;
    }
  }
}