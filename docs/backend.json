
{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "Representa una propiedad inmobiliaria (casa, apartamento, local).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "enum": ["Casa", "Apartamento", "Local Comercial", "Oficina", "Quinta"] },
        "operationType": { "enum": ["Venta", "Alquiler"], "description": "Define si la propiedad está para vender o alquilar." },
        "province": { "enum": ["San José", "Alajuela", "Cartago", "Heredia", "Guanacaste", "Puntarenas", "Limón"] },
        "city": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "parking": { "type": "number" },
        "area_m2": { "type": "number" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "mapUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "price", "type", "province", "city", "imageUrls", "operationType"]
    },
    "Lot": {
      "title": "Lot",
      "description": "Representa un lote o terreno en venta.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "province": { "enum": ["San José", "Alajuela", "Cartago", "Heredia", "Guanacaste", "Puntarenas", "Limón"] },
        "city": { "type": "string" },
        "area_m2": { "type": "number" },
        "topography": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "mapUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "price", "province", "city", "area_m2", "imageUrls"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": { "$ref": "#/entities/Property" },
      "description": "Colección pública de propiedades disponibles."
    },
    "/lots/{lotId}": {
      "schema": { "$ref": "#/entities/Lot" },
      "description": "Colección pública de lotes y terrenos."
    }
  }
}
