
{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "Represents a real estate property (house, apartment, etc.) for sale or rent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "Nombre o título de la propiedad." },
        "description": { "type": "string", "description": "Descripción detallada." },
        "price": { "type": "number", "description": "Precio en colones o dólares." },
        "type": { "type": "string", "enum": ["Casa", "Apartamento", "Local Comercial", "Oficina"] },
        "province": { "type": "string", "enum": ["San José", "Alajuela", "Cartago", "Heredia", "Guanacaste", "Puntarenas", "Limón"] },
        "city": { "type": "string" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "area_m2": { "type": "number" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "type", "province", "imageUrls"]
    },
    "Lot": {
      "title": "Lot",
      "description": "Represents a plot of land or lot for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "province": { "type": "string", "enum": ["San José", "Alajuela", "Cartago", "Heredia", "Guanacaste", "Puntarenas", "Limón"] },
        "city": { "type": "string" },
        "area_m2": { "type": "number" },
        "topography": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "province", "area_m2", "imageUrls"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Contact requests from interested clients.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "propertyId": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Closed"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" },
      "description": "Public collection of properties."
    },
    "/lots/{lotId}": {
      "schema": { "$ref": "#/backend/entities/Lot" },
      "description": "Public collection of lots."
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/backend/entities/Lead" },
      "description": "Private contact requests."
    }
  }
}
